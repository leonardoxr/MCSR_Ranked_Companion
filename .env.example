# MCSR Ranked Companion - Environment Variables
# Copy this file to .env.local and fill in the values as needed.

# Optional: Canonical public site URL used for metadata, robots, and sitemap.
# NEXT_PUBLIC_SITE_URL=https://mcsr-ranked-companion.vercel.app

# Optional: Custom MCSR API base URL (defaults to https://api.mcsrranked.com)
# NEXT_PUBLIC_MCSR_API_BASE_URL=https://api.mcsrranked.com
