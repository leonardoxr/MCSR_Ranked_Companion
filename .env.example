# MCSR Ranked Companion - Environment Variables
# Copy this file to .env.local and fill in the values as needed.

# Optional: Custom MCSR API base URL (defaults to https://mcsrranked.com/api)
# NEXT_PUBLIC_MCSR_API_BASE_URL=https://api.mcsrranked.com

# Optional: API key for MCSR Ranked API (for enhanced rate limits)
# NEXT_PUBLIC_MCSR_API_KEY=your_api_key_here
