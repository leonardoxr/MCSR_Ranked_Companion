{
  "productName": "MCSR Ranked Companion",
  "version": "1.0.0",
  "identifier": "com.mcsrranked.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:tauri",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "MCSR Ranked Companion",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "transparent": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "A companion app for MCSR Ranked players",
    "longDescription": "A beautiful, fast, and feature-rich cross-platform companion app for MCSR (Minecraft Speedrun) Ranked players. Track statistics, view leaderboards, and watch live matches."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}

